{
    "name": "lukaszzychal/nbp-api-client-php",
    "description": "Biblioteka PHP do obsługi oficjalnego API NBP (Narodowy Bank Polski) - pobieranie kursów walut, cen złota w formacie DTO.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lukasz Zychal"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-bcmath": "*",
        "psr/cache": "^3.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10 || ^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/http-client": "^6.0 || ^7.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "LukaszZychal\\NbpApiClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LukaszZychal\\NbpApiClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:contract": "phpunit --group contract",
        "analyze": "phpstan analyse src tests --level max",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@cs",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
