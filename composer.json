{
    "name": "lukaszzychal/nbp-api-client-php",
    "description": "PHP client library for the official NBP (National Bank of Poland) API. Fetches currency exchange rates and gold prices as typed DTOs with PSR-3, PSR-6, PSR-7, PSR-17, PSR-18 support.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nbp",
        "national-bank-of-poland",
        "currency",
        "exchange-rate",
        "gold-price",
        "psr-6",
        "psr-18",
        "api-client",
        "php"
    ],
    "homepage": "https://github.com/lukaszzychal/nbp-api-client-php",
    "authors": [
        {
            "name": "Lukasz Zychal",
            "email": "lukasz.zychal.dev@gmail.com",
            "role": "Developer",
            "homepage": "https://github.com/lukaszzychal"
        }
    ],
    "support": {
        "issues": "https://github.com/lukaszzychal/nbp-api-client-php/issues",
        "source": "https://github.com/lukaszzychal/nbp-api-client-php"
    },
    "require": {
        "php": ">=8.1",
        "ext-bcmath": "*",
        "psr/cache": "^3.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10 || ^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/http-client": "^6.0 || ^7.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "LukaszZychal\\NbpApiClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LukaszZychal\\NbpApiClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:contract": "phpunit --group contract",
        "analyze": "phpstan analyse src tests --level max",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@cs",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.1.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}